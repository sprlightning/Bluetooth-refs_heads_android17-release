package: "com.android.bluetooth.flags"
container: "com.android.bt"

flag {
    name: "trigger_sec_proc_on_inc_access_req"
    namespace: "bluetooth"
    description: "Trigger security procedure as acceptor as needed"
    bug: "376278485"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "retain_address_type"
    namespace: "bluetooth"
    description: "Set correct address type in BluetoothDevice objects created by the Android Bluetooth"
    bug: "407277344"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "fix_ongoing_rnr_while_bonding"
    namespace: "bluetooth"
    description: "Fix pairing failure when RNR ongoing"
    bug: "430623282"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "skip_excess_name_discovery"
    namespace: "bluetooth"
    description: "Skip name discovery during BR/EDR pairing if the name is already known"
    bug: "434973460"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "conclude_le_pairing_immediately"
    namespace: "bluetooth"
    description: "Do add unnecessary delay to conclude LE pairing"
    bug: "436319185"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "reject_bond_request_during_bonding"
    namespace: "bluetooth"
    description: "Don't accept new bond request when bonding"
    bug: "439861848"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "btm_iocaps_sysprop_override"
    namespace: "bluetooth"
    description: "Override IO capabilities using system properties"
    bug: "446939944"
}

flag {
    name: "apairing_26q2_permission_improvements"
    namespace: "bluetooth"
    description: "Permission improvements for pairing in 26Q2"
    bug: "449010608"
    is_exported: true
}

flag {
    name: "detect_bondloss_legacy_bredr_pairing"
    namespace: "bluetooth"
    description: "Detect bond loss during legacy BR/EDR pairing"
    bug: "455785260"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "provide_pairing_algo"
    namespace: "bluetooth"
    description: "Add pairing algorithm in pairing request"
    bug: "453979807"
    is_exported: true
}

flag {
    name: "autonomous_repairing_initiation"
    namespace: "bluetooth"
    description: "Initiate autonomous re-pairing when bond loss is detected."
    bug: "459695529"
    is_exported: true
}

flag {
    name: "btm_disconnect_on_remove"
    namespace: "bluetooth"
    description: "BTM must disconnect any connection when bond is removed"
    bug: "461581261"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "security_mode_3_pairing"
    namespace: "bluetooth"
    description: "Fixes pairing with devices which are in BR/EDR security mode 3."
    bug: "460502961"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "prevent_btm_sec_cb_overwrite_during_pairing"
    namespace: "bluetooth"
    description: "If the pairing state is not idle, do not overwrite btm_sec_cb"
    bug: "467193133"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "non_ctkd_dual_mode_pairing"
    namespace: "bluetooth"
    description: "Allow applications to initiate separate pairing for different transports with non-CTKD supporting dual mode devices"
    bug: "467761282"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "cancel_pairing_while_remove_bond"
    namespace: "bluetooth"
    description: "Cancel the ongoing pairing or SDP when remove bond is called."
    bug: "472917739"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "check_bond_status_before_pairing"
    namespace: "bluetooth"
    description: "Check bond status of the device and transport before proceeding with a new pairing request"
    bug: "473128699"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "force_encryption_post_successful_pairing"
    namespace: "bluetooth"
    description: "Force encryption after successful pairing"
    bug: "472946151"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "update_cod_on_incoming_connection"
    namespace: "bluetooth"
    description: "Update class of device from incoming connection request"
    bug: "474364095"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "pairing_transport_selection"
    namespace: "bluetooth"
    description: "Consider device discovery information while selecting pairing transport"
    bug: "478355960"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "bugfix_autonomous_repairing"
    namespace: "bluetooth"
    description: "Add generic bugfixes for autonomous repairing feature."
    bug: "481170402"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "process_iocap_rsp_while_repairing"
    namespace: "bluetooth"
    description: "Process HCI IO capability response when received for repairing."
    bug: "487510188"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "link_key_request_timer"
    namespace: "bluetooth"
    description: "Wait for CTKD to complete when Link Key is requested"
    bug: "488024640"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}

flag {
    name: "remove_bond_in_idle_state"
    namespace: "bluetooth"
    description: "Remove bond without transitioning BondStateMachine to bonding state"
    bug: "489217572"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}


flag {
    name: "remove_bond_caller_info"
    namespace: "bluetooth"
    description: "Remove bond caller information when bonding is concluded"
    bug: "492665910"
    metadata {
        purpose: PURPOSE_BUGFIX
    }
}
