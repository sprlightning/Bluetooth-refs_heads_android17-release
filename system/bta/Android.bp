package {
    // See: http://go/android-license-faq
    // A large-scale-change added 'default_applicable_licenses' to import
    // all of the 'license_kinds' from "system_bt_license"
    // to get the below license kinds:
    //   SPDX-license-identifier-Apache-2.0
    default_applicable_licenses: ["system_bt_license"],
}

cc_defaults {
    name: "fluoride_bta_defaults",
    defaults: ["fluoride_defaults"],
    local_include_dirs: [
        "dm",
        "hd",
        "hh",
        "include",
        "sys",
    ],
    include_dirs: [
        "packages/modules/Bluetooth/system",
        "packages/modules/Bluetooth/system/bta/include",
        "packages/modules/Bluetooth/system/btif/avrcp",
        "packages/modules/Bluetooth/system/gd",
        "packages/modules/Bluetooth/system/stack/btm",
        "packages/modules/Bluetooth/system/udrv/include",
    ],
    header_libs: ["libbluetooth_headers"],
}

filegroup {
    name: "BtaDmSources",
    srcs: [
        "dm/bta_dm_act.cc",
        "dm/bta_dm_api.cc",
        "dm/bta_dm_cfg.cc",
        "dm/bta_dm_ci.cc",
        "dm/bta_dm_device_search.cc",
        "dm/bta_dm_disc.cc",
        "dm/bta_dm_disc_sdp.cc",
        "dm/bta_dm_gatt_client.cc",
        "dm/bta_dm_main.cc",
        "dm/bta_dm_pm.cc",
        "dm/bta_dm_pm_offload.cc",
        "dm/bta_dm_sec.cc",
        "dm/bta_dm_sec_api.cc",
        "dm/sniff_offload/sniff_offload.cc",
        "dm/sniff_offload/sniff_offload_config_reader.cc",
        "dm/sniff_offload/sniff_offload_vsc_sender.cc",
    ],
}

filegroup {
    name: "TestMockCodecManager",
    srcs: [
        "le_audio/mock_codec_manager.cc",
    ],
}

