        "hh/bta_hh_main.cc",
        "hh/bta_hh_utils.cc",
        "jv/bta_jv_act.cc",
        "jv/bta_jv_api.cc",
        "le_audio/ascs/ascs.cc",
        "le_audio/ascs/ase_manager.cc",
