        host: {
            sanitize: {
                address: true,

            },
            srcs: [
                "hal/hci_hal_impl_host_rootcanal_test.cc",
            ],
        },
        android: {
            sanitize: {
                // TODO(b/484475434): Mts fails with asan
                address: false,
                cfi: false,
            },
            srcs: [
                "hal/hci_hal_impl_android_test.cc",
                "os/android/wakelock_native_test.cc",
            ],
            static_libs: [
