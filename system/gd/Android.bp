    srcs: [
        ":BluetoothPacketTestSources",
        ":TestCommonMockFunctions",
        ":TestMockMainShim",
        ":TestMockMainShimEntry",
        "common/bidi_queue_unittest.cc",
        "common/blocking_queue_unittest.cc",
