cc_library_static {
    name: "libbluetooth_gd_fuzzing",
    defaults: [
        "libbluetooth_gd_defaults",
    ],
    include_dirs: [
        "packages/modules/Bluetooth/system",
    ],
    srcs: [
        "os/fake_timer/fake_timerfd.cc",
    ],
    cflags: [
        "-DFUZZ_TARGET",
        "-DUSE_FAKE_TIMERS",
    ],
    static_libs: [
        "bluetooth_flags_c_lib_for_test",
        "libbluetooth_types",
        "libbt-common",
        "libchrome",
        "libosi",
    ],
}

cc_library_static {
    name: "libbluetooth_gd_unit_tests",
    defaults: [
        "libbluetooth_gd_defaults",
    ],
    include_dirs: [
        "packages/modules/Bluetooth/system",
    ],
    srcs: [
        "os/fake_timer/fake_timerfd.cc",
    ],
    cflags: [
        "-DUSE_FAKE_TIMERS",
    ],
    static_libs: [
        "bluetooth_flags_c_lib_for_test",
        "libbluetooth_types",
        "libbt-common",
        "libchrome",
        "libosi",
    ],
}

cc_test {
    name: "bluetooth_test_with_timerfd",
    test_suites: ["general-tests"],
    defaults: [
        "gd_defaults",
        "mts_defaults",
    ],
    include_dirs: [
        "packages/modules/Bluetooth/system",
        "packages/modules/Bluetooth/system/include",
    ],
    host_supported: true,
    target: {
        host: {
            srcs: ["os/host/system_properties.cc"],
            sanitize: {
                address: true,
            },
        },
        android: {
            srcs: ["os/android/system_properties.cc"],
            sanitize: {
                address: false, // TODO(b/481480264) - Mts can't run with asan
            },
        },
    },
    srcs: [
        "os/handler.cc",
        "os/linux_generic/alarm.cc",
        "os/linux_generic/alarm_timerfd_unittest.cc",
        "os/linux_generic/boottime_clock.cc",
        "os/linux_generic/files.cc",
        "os/linux_generic/reactive_semaphore.cc",
        "os/linux_generic/reactor.cc",
        "os/linux_generic/repeating_alarm.cc",
        "os/linux_generic/thread.cc",
        "os/linux_generic/timed_mutex.cc",
    ],
    static_libs: [
        "bluetooth_flags_c_lib_for_test",
        "libaconfig_storage_read_api_cc",
        "libbluetooth_log",
        "libbluetooth_types",
        "libchrome",
        "libgmock",
        "server_configurable_flags",
    ],
    shared_libs: [
        "libbase",
        "liblog",
    ],
    min_sdk_version: "36",
}

/**
 * This tests module will test with a real timer. It is not included in the
 * bluetooth_test_gd_unit test because it may take too long to run on
 * Android as it uses a real timer.
 */
cc_test {
    name: "bluetooth_test_gd_unit_rt",
    test_suites: ["general-tests"],
    defaults: [
        "gd_defaults",
        "mts_defaults",
    ],
    include_dirs: [
        "packages/modules/Bluetooth/system",
        "packages/modules/Bluetooth/system/include",
    ],
    host_supported: true,
    // TODO(b/231993739): Reenable isolated:true by deleting the explicit disable below
    isolated: false,
    srcs: [
        "os/handler_unittest_rt.cc",
    ],
    static_libs: [
        "bluetooth_flags_c_lib_for_test",
        "libPlatformProperties",
        "libbase",
        "libbluetooth_crypto_toolbox",
        "libbluetooth_gd",
        "libbluetooth_log",
        "libbt-common",
        "libbtdevice",
        "libchrome",
        "libcom.android.sysprop.bluetooth.wrapped",
        "libflagtest",
        "libflatbuffers-cpp",
        "libgmock",
        "libosi",
        "server_configurable_flags",
    ],
    shared_libs: [
        "libaconfig_storage_read_api_cc",
        "libcrypto",
        "liblog",
    ],
    sanitize: {
        // TODO(b/484475434): Mts fails with asan
        address: false,
    },
    min_sdk_version: "36",
}

cc_test {
    name: "bluetooth_test_gd_unit",
    test_suites: ["general-tests"],
    defaults: [
        "gd_defaults",
        "mts_defaults",
    ],
    include_dirs: [
        "packages/modules/Bluetooth/system",
        "packages/modules/Bluetooth/system/include",
    ],
    host_supported: true,
    // TODO(b/231993739): Reenable isolated:true by deleting the explicit disable below
    isolated: false,
    target: {
        linux: {
            sanitize: {
                address: true,
            },
            srcs: [
                "os/linux_generic/alarm_unittest.cc",
                "os/linux_generic/files_test.cc",
                "os/linux_generic/queue_unittest.cc",
                "os/linux_generic/reactor_unittest.cc",
                "os/linux_generic/repeating_alarm_unittest.cc",
