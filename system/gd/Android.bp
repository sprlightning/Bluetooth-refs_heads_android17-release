package {
    // See: http://go/android-license-faq
    // A large-scale-change added 'default_applicable_licenses' to import
    // all of the 'license_kinds' from "system_bt_license"
    // to get the below license kinds:
    //   SPDX-license-identifier-Apache-2.0
    //   SPDX-license-identifier-BSD
    default_applicable_licenses: ["system_bt_license"],
}

cc_defaults {
    name: "gd_defaults",
    defaults: [
        "bluetooth_cflags",
        "bluetooth_tidy",
    ],
    target: {
        android: {
            test_config_template: "AndroidTestTemplate.xml",
            shared_libs: [
                "liblog",
            ],
            // sanitize: {
            //     misc_undefined: ["bounds"],
            // },
        },
        darwin: {
            enabled: false,
        },
    },
    cflags: [
        "-DEXPORT_SYMBOL=__attribute__((visibility(\"default\")))",
        "-DGOOGLE_PROTOBUF_NO_RTTI",
        "-DLOG_NDEBUG=0",
        "-fvisibility=hidden",
    ],
    header_libs: ["jni_headers"],
}

cc_defaults {
    name: "libbluetooth_gd_defaults",
    defaults: [
        "gd_defaults",
        "libbluetooth_gd_os_defaults",
    ],
    host_supported: true,
    target: {
        host: {
            srcs: [
                "hal/hci_hal_impl_host_rootcanal.cc",
                "os/host/parameter_provider.cc",
                "os/host/system_properties.cc",
                "os/host/wakelock_native.cc",
            ],
        },
        android: {
            srcs: [
                "hal/gatt_hal_impl_android.cc",
                "hal/hci_backend_aidl.cc",
                "hal/hci_backend_hidl.cc",
                "hal/hci_hal_impl_android.cc",
                "hal/ranging_hal_impl_android.cc",
                "hal/socket_hal_impl_android.cc",
                "os/android/parameter_provider.cc",
                "os/android/system_properties.cc",
                "os/android/wakelock_native.cc",
            ],
            shared_libs: [
                "android.hardware.bluetooth@1.0",
                "android.hardware.bluetooth@1.1",
                "android.system.suspend-V1-ndk",
                "android.system.suspend.control-V1-ndk",
                "libbinder_ndk",
                "libcutils",
                "libhidlbase",
                "libstatssocket",
                "libutils",
            ],
            static_libs: [
                "libperfetto_client_experimental",
            ],
            whole_static_libs: [
                "android.hardware.bluetooth-V1-ndk",
                "android.hardware.bluetooth.gatt-V1-ndk",
                "android.hardware.bluetooth.ranging-V2-ndk",
                "android.hardware.bluetooth.socket-V1-ndk",
                "android.hardware.contexthub-V4-ndk",
            ],
        },
    },
    srcs: [
        ":BluetoothPacketSources",
        "common/audit_log.cc",
        "common/stop_watch.cc",
        "common/utils.cc",
        "common/watchdog.cc",
        "hal/link_clocker.cc",
        "hal/snoop_logger.cc",
        "hal/snoop_logger_file.cc",
        "hal/snoop_logger_socket.cc",
        "hal/snoop_logger_socket_thread.cc",
        "hal/snoop_logger_tracing.cc",
        "hal/syscall_wrapper_impl.cc",
        "hci/acl_manager/acl_connection.cc",
        "hci/acl_manager/acl_fragmenter.cc",
        "hci/acl_manager/acl_manager_classic_impl.cc",
        "hci/acl_manager/acl_manager_le_impl.cc",
        "hci/acl_manager/acl_scheduler.cc",
        "hci/acl_manager/classic_acl_connection.cc",
        "hci/acl_manager/le_acl_connection.cc",
        "hci/acl_manager/round_robin_scheduler.cc",
        "hci/channel_sounding/cs_metrics.cc",
        "hci/controller_impl.cc",
        "hci/distance_measurement_manager_impl.cc",
        "hci/hci_layer.cc",
        "hci/hci_metrics_logging.cc",
        "hci/le_address_manager.cc",
        "hci/le_advertising_manager_impl.cc",
        "hci/le_scanning_manager_impl.cc",
        "hci/le_scanning_reassembler.cc",
        "hci/msft.cc",
        "hci/remote_name_request_impl.cc",
        "lpp/lpp_offload_manager.cc",
        "os/rand.cc",
        "os/system_properties_common.cc",
        "storage/config_cache.cc",
        "storage/config_cache_helper.cc",
        "storage/device.cc",
        "storage/legacy_config_file.cc",
        "storage/storage_module.cc",
    ],
    shared_libs: [
        "libcrypto",
        "libflatbuffers-cpp",
        "liblog",
    ],
    export_shared_lib_headers: [
        "libflatbuffers-cpp",
    ],
    whole_static_libs: [
        "libbluetooth_hci_pdl",
        "libbluetooth_l2cap_pdl",
        "libbluetooth_ras_pdl",
        "libbluetooth_smp_pdl",
    ],
    static_libs: [
        "libaconfig_storage_read_api_cc",
        "libbase",
        "libbluetooth_crypto_toolbox",
        "libbluetooth_log",
        "libbluetooth_metrics",
        "libbluetooth_types",
        "libbt-common",
        "libcom.android.sysprop.bluetooth.wrapped",
        "libosi",
        "server_configurable_flags",
    ],
    include_dirs: [
        "packages/modules/Bluetooth/system/include",
    ],
}

cc_library_static {
    name: "libbluetooth_gd_os",
    defaults: [
        "libbluetooth_gd_os_defaults",
    ],
    include_dirs: [
        "packages/modules/Bluetooth/system",
    ],
    apex_available: ["com.android.bt"],
    min_sdk_version: "36",
    static_libs: [
        "bluetooth_flags_c_lib",
        "libchrome",
    ],
}

cc_library_static {
    name: "libbluetooth_gd_os_mock",
    defaults: ["gd_defaults"],
    host_supported: true,
    test_only: true,
    srcs: [
        "os/rand.cc",
    ],
    static_libs: [
        "libbluetooth_log",
        "libgmock",
    ],
    shared_libs: [
        "libcrypto",
    ],
    include_dirs: ["packages/modules/Bluetooth/system/gd"],
}

