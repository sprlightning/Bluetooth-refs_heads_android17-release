package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

python_library_host {
    name: "navi-lib",
    srcs: [
        "navi/**/*.py",
    ],
    libs: [
        "absl-py",
        "bumble",
        "mobly",
        "py-grpcio",
        "py-snippet-uiautomator",
        "typing_extensions",
    ],
}

python_test_host {
    name: "navi-mobly",
    main: "main.py",
    srcs: [
        "main.py",
    ],
    embedded_launcher: true,
    test_config: "Mobly.xml",
    test_suites: [
        "general-tests",
    ],
    test_options: {
        unit_test: false,
        runner: "mobly",
    },
    device_common_data: [
        ":BluetoothSnippet",
    ],
    data: [
        "navi/tests/data/**/*",
    ],
    libs: [
        "navi-lib",
    ],
}

// For Coverage only.
python_test_host {
    name: "navi-tf",
    main: "main.py",
    srcs: [
        "main.py",
    ],
    embedded_launcher: true,
    test_config: "Tradefed.xml",
    test_suites: [
        "general-tests",
        "mts-bt",
    ],
    test_options: {
        unit_test: false,
    },
    data: [
        "config.yml",
        "navi/tests/data/**/*",
    ],
    device_common_data: [
        ":BluetoothSnippet",
    ],
    libs: [
        "navi-lib",
    ],
}
