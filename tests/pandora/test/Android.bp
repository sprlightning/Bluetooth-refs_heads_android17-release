package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

python_test_host {
    name: "avatar",
    main: "main.py",
    srcs: [
        "**/*.py",
    ],
    embedded_launcher: true,
    libs: [
        "bumble",
        "bumble-pandora-services",
        "libprotobuf-python",
        "mobly",
        "pandora_interfaces-python",
        "py-grpcio",
    ],
    required: [
        "aapt",
    ],
    test_suites: [
        "general-tests",
        "mts-bt",
    ],
    test_options: {
        unit_test: false,
    },
    data: [
        "config.yml",
    ],
    device_common_data: [
        ":PandoraServer",
    ],
}

python_test_host {
    name: "avatar_phy",
    main: "main.py",
    srcs: [
        "**/*.py",
    ],
    test_config: "AndroidPhyTest.xml",
    embedded_launcher: false,
    libs: [
        "bumble",
        "bumble-pandora-services",
        "libprotobuf-python",
        "mobly",
        "pandora_interfaces-python",
    ],
    required: [
        "aapt",
    ],
    test_suites: ["general-tests"],
    test_options: {
        unit_test: false,
    },
    data: [
        "config.yml",
    ],
    device_common_data: [
        ":PandoraServer",
    ],
}

sh_binary_host {
    name: "avatar.sh",
    src: "avatar.sh",
    required: [
        "avatar",
        "pandora_interfaces-python-gen-src",
        "tradefed",
    ],
}
