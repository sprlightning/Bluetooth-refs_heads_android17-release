package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

android_test {
    name: "ServiceBluetoothTests",
    defaults: ["service-bluetooth-buildflags"],

    lint: {
        test: true,
    },

    srcs: ["src/**/*.java"],

    static_libs: [
        "androidx.test.espresso.intents",
        "androidx.test.rules",
        "bluetooth-common-testutils",
        "flag-junit",
        "frameworks-base-testutils",
        "kotlinx_coroutines_test",
        "libprotobuf-java-nano",
        "mockito-target-extended",
        "platform-compat-test-rules",
        "platform-parametric-runner-lib",
        "platform-test-annotations",
        "service-bluetooth-binder-aidl",
        "service-bluetooth-pre-jarjar",
        "truth",
    ],

    libs: [
        "android.test.base.stubs.system",
        "android.test.mock.stubs.system",
        "android.test.runner.stubs.system",
        "framework-permission-s.stubs.module_lib",
    ],

    jni_libs: [
        // these are needed for Extended Mockito
        "libdexmakerjvmtiagent",
        "libstaticjvmtiagent",
    ],

    test_suites: [
        "general-tests",
        "mts-bluetooth",
        "mts-bt",
    ],

    jacoco: {
        include_filter: [
            "android.bluetooth.**",
            "com.android.bluetooth.**",
            "com.android.server.bluetooth.**",
        ],
        exclude_filter: [],
    },

    sdk_version: "test_current",
    min_sdk_version: "36",
}
